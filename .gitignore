__pycache__/
*.pyc
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tmp/
.test-workspaces/
probe_*.sqlite*
testprobe.sqlite*
.venv/
venv/
build/
dist/
*.egg-info/

# Local secrets. Keep the example file committed, but never commit real keys.
config/api-keys.toml

# Generated workspace content. Keep directory skeletons, not local research output.
sources/raw/*
!sources/raw/.gitkeep
sources/normalized/*
!sources/normalized/.gitkeep

state/*.sqlite
state/*.sqlite-*
state/*.db
state/*.db-*
state/embeddings/

# Staging runs are review workspaces; keep the directory but do not commit runs by default.
staging/*
!staging/.gitkeep

# Compiled wiki pages generated from local sources.
wiki/index.md
wiki/log.md
wiki/sources/*.md
wiki/concepts/*.md
wiki/entities/*.md
wiki/syntheses/*.md

# Local thinking notes.
LLM Wiki 思考.md
